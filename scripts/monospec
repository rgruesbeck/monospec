#!/usr/bin/env bash
set -euo pipefail

if [[ -z "${MONOSPEC_ROOT:-}" ]]; then
  echo "error: MONOSPEC_ROOT is not set. Run install.sh to configure." >&2
  exit 1
fi

cmd="${1:-}"
shift || true

case "$cmd" in
  init)
    if [[ -n "${1:-}" ]]; then
      project_name="$1"
      shift
    else
      project_name="$(basename "$PWD")"
    fi
    target="$MONOSPEC_ROOT/projects/$project_name/openspec"

    if [[ -L "./openspec" ]]; then
      existing_target="$(readlink "./openspec")"
      if [[ "$existing_target" == "$target" ]]; then
        echo "already initialized: ./openspec -> $target"
        exit 0
      else
        echo "error: ./openspec is already a symlink pointing to $existing_target" >&2
        echo "       Remove it manually if you want to reinitialize." >&2
        exit 1
      fi
    elif [[ -e "./openspec" ]]; then
      echo "An openspec directory already exists at $(pwd)/openspec."
      echo ""
      echo "  1) Start fresh      — delete the existing directory and run openspec init"
      echo "  2) Move to monospec — migrate the existing directory to $target"
      echo ""
      read -rp "Choose [1/2]: " choice
      case "$choice" in
        1)
          rm -rf ./openspec
          ;;
        2)
          mv ./openspec "$target"
          ln -s "$target" ./openspec
          echo "migrated:    $(pwd)/openspec -> $target"
          gitignore="./.gitignore"
          if ! grep -qxF '/openspec' "$gitignore" 2>/dev/null; then
            echo '/openspec' >> "$gitignore"
            echo "gitignore:   added /openspec to $gitignore"
          fi
          exit 0
          ;;
        *)
          echo "Aborted." >&2
          exit 1
          ;;
      esac
    fi

    mkdir -p "$target"
    ln -s "$target" ./openspec
    echo "initialized: $target"
    echo "symlinked:   $(pwd)/openspec -> $target"

    gitignore="./.gitignore"
    if ! grep -qxF '/openspec' "$gitignore" 2>/dev/null; then
      echo '/openspec' >> "$gitignore"
      echo "gitignore:   added /openspec to $gitignore"
    fi

    openspec init "$@"
    ;;
  *)
    echo "usage: monospec <command> [args]"
    echo ""
    echo "commands:"
    echo "  init [project-name]   initialize openspec for a project (defaults to current dir name)"
    exit 1
    ;;
esac
